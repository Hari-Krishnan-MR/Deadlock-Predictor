*.pkl
*.joblib
*.model

# Jupyter checkpoints  
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# Python cache  
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environment  
venv/
env/
.env
*.env

# OS files            ─
.DS_Store
Thumbs.db
desktop.ini

# VS Code              
.vscode/
*.code-workspace

# Outputs (regenerated by notebooks)             
outputs/models/*.pkl